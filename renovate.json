{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "enabledManagers": ["custom.regex"],
  "gitAuthor": "ops-renovate <48201364+salt-mountain@users.noreply.github.com>",
  "dependencyDashboard": false,
  "internalChecksFilter": "strict",
  "vulnerabilityAlerts": { "enabled": false },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [".github/workflows/verify.yml"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)\\s+default:\\s*\"(?<currentValue>[^\"]+)\""
      ],
      "extractVersionTemplate": "^bun-v(?<version>.+)$",
      "versioningTemplate": "semver"
    }
  ],
  "packageRules": [
    { "matchUpdateTypes": ["major"], "minimumReleaseAge": "30 days" },
    { "matchUpdateTypes": ["minor", "patch"], "minimumReleaseAge": "7 days" }
  ]
}
